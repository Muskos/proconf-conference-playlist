{
  "compilerOptions": {
    "target": "es2017",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true
  },
  "include": ["config.ts", "main.ts", "src/**/*.ts"],
  "exclude": ["dist", "node_modules"],
  "ts-node": {
    "esm": true
  }
}
